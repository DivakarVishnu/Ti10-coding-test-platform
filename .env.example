# Flask
SECRET_KEY=replace-with-a-long-random-string

# Database (leave unset/commented to use local SQLite file - fine for a single VM/college server)
# For Render/Railway/Heroku, set this to a Postgres URL for persistence across deploys.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---- Judge0 (choose ONE option below) ----

# Option A (DEFAULT - free, zero setup): Judge0's own public instance.
# No key needed. Fine for testing / light use. Can be slow under heavy concurrent load.
JUDGE0_URL=https://ce.judge0.com
RAPIDAPI_KEY=
RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Option B (self-hosted, unlimited & free, needs a server/VM with Docker) - recommended for real exams:
# git clone https://github.com/judge0/judge0.git && cd judge0 && docker compose up -d
# JUDGE0_URL=http://localhost:2358
# (leave RAPIDAPI_KEY blank)

# Option C (RapidAPI Judge0 CE - now pay-per-use, needs a card on file):
# JUDGE0_URL=https://judge0-ce.p.rapidapi.com
# RAPIDAPI_KEY=your-rapidapi-key-here
